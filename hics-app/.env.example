# OpenAI API key - used by api/chat.js for the AI training chatbot (server-side only)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Optional webhook to relay notifications (password resets, session warnings, completion notices)
# Example: Slack, Teams, Zapier, custom email worker
NOTIFICATION_WEBHOOK_URL=

# Optional durable API store settings (used by serverless API routes)
# If UPSTASH_REDIS_REST_URL and UPSTASH_REDIS_REST_TOKEN are set, API data persists in Redis.
# Otherwise, API falls back to a local JSON file path.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
HICS_STORE_REDIS_KEY=nyx:hics:store:v1

# Optional file path override when not using Redis
HICS_STORE_FILE_PATH=.nyx-hics-store.json

# Frontend base URL for protected API calls
# For same-origin Vercel deployment with serverless routes under /api, use /api
VITE_API_BASE_URL=/api

# Frontend endpoint used to exchange OIDC auth code for app tokens
VITE_AUTH_EXCHANGE_ENDPOINT=/api/auth/exchange

# Optional local-only fallback flags (do not enable in production)
VITE_ALLOW_LOCAL_AUTH_FALLBACK=false
VITE_ALLOW_LOCAL_LEAD_FALLBACK=false

# Microsoft Entra OIDC settings
VITE_OIDC_ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000000
VITE_OIDC_ENTRA_AUTHORIZE_URL=https://login.microsoftonline.com/<tenant-id>/oauth2/v2.0/authorize
VITE_OIDC_ENTRA_SCOPE=openid profile email offline_access

# Okta OIDC settings
VITE_OIDC_OKTA_CLIENT_ID=0oa0000000000000000
VITE_OIDC_OKTA_AUTHORIZE_URL=https://<your-okta-domain>/oauth2/default/v1/authorize
VITE_OIDC_OKTA_SCOPE=openid profile email offline_access
